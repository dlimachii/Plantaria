APP_NAME=Plantaria
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=plantaria
DB_USERNAME=plantaria
DB_PASSWORD=

PLANTARIA_ADMIN_HANDLE=plantaria_admin
PLANTARIA_ADMIN_NAME="Plantaria Admin"
PLANTARIA_ADMIN_EMAIL=admin@plantaria.local
# Required for `php artisan migrate --seed` (do not commit real passwords).
PLANTARIA_ADMIN_PASSWORD=
PLANTARIA_DEMO_PASSWORD=
PLANTARIA_USER_PASSWORD=
PLANTARIA_MOD_PASSWORD=

NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="Plantaria/1.0 (local geocoding proxy)"

PLANTARIA_ANALYTICS_PYTHON=python3
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_ENABLED=true

CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1:8000,http://localhost:3000,https://dlimachii.com,https://api.dlimachii.com
CORS_SUPPORTS_CREDENTIALS=false

PLANTARIA_ADMIN_SQL_READONLY_ENABLED=true
PLANTARIA_ADMIN_SQL_MAX_ROWS=200
PLANTARIA_ADMIN_SQL_MAX_LENGTH=4000
PLANTARIA_ADMIN_SQL_TIMEOUT_MS=4000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
